# Copy this file to `.env.local` (never commit it). Without these vars the
# app runs in local-only mode — every feature works, but songs stay on the
# device and there's no sign-in. See docs/SUPABASE-SETUP.md for the full
# step-by-step.

# --- Supabase (cloud auth + per-user song sync) -------------------------
# From Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Vercel Cron keep-alive --------------------------------------------
# Any random string (e.g. `openssl rand -hex 32`). Used to authorise manual
# tests of /api/keepalive; the scheduled cron itself is authorised via the
# Vercel cron header.
CRON_SECRET=

# --- Firebase (legacy; optional) ---------------------------------------
# The old Firestore adapter still works if you'd rather not run Supabase.
# Leave blank for Supabase (or local-only).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
